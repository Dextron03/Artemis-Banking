@model ArtemisBanking.ViewModels.CreditCardDetailViewModel
@{
    ViewData["Title"] = "Detalle de la Tarjeta";
    var card = Model.Card;
    var available = card.CreditLimit - card.AmountDebt;
    var usedPct = card.CreditLimit > 0 ? (double)(card.AmountDebt / card.CreditLimit * 100) : 0;
    var barColor = usedPct > 80 ? "bg-danger" : usedPct > 50 ? "bg-warning" : "bg-success";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-eye text-primary me-2"></i>Detalle de Tarjeta
            </h2>
            <span class="text-muted small">
                <code>**** **** **** @card.LastFourDigits</code> — @card.ClientFullName
            </span>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Volver atrás
        </a>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small fw-semibold mb-1">Límite de crédito</div>
                    <div class="fs-5 fw-bold text-success">@card.CreditLimit.ToString("C2")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small fw-semibold mb-1">Deuda actual</div>
                    <div class="fs-5 fw-bold @(card.AmountDebt > 0 ? "text-danger" : "text-muted")">
                        @card.AmountDebt.ToString("C2")
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small fw-semibold mb-1">Disponible</div>
                    <div class="fs-5 fw-bold text-primary">@available.ToString("C2")</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small fw-semibold mb-1">Vencimiento</div>
                    <div class="fs-5 fw-bold">@card.ExpireDate</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-1">
                <span class="small fw-semibold text-muted">Uso del crédito</span>
                <span class="small fw-semibold">@usedPct.ToString("F1")%</span>
            </div>
            <div class="progress" style="height:8px">
                <div class="progress-bar @barColor" style="width:@usedPct.ToString("F1")%"></div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between py-3">
            <span class="fw-bold">
                <i class="bi bi-list-ul me-2 text-primary"></i>Historial de Consumos
            </span>
            <span class="badge bg-secondary rounded-pill">@card.Consumptions.Count transacción(es)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha</th>
                            <th class="text-end">Monto</th>
                            <th>Comercio</th>
                            <th class="text-center">Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!card.Consumptions.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-receipt fs-2 d-block mb-2"></i>
                                    No hay consumos registrados para esta tarjeta.
                                </td>
                            </tr>
                        }
                        @foreach (var c in card.Consumptions)
                        {
                            <tr>
                                <td>
                                    <span class="fw-semibold">@c.ConsumptionDate.ToString("dd/MM/yyyy")</span>
                                    <span class="d-block text-muted small">@c.ConsumptionDate.ToString("HH:mm")</span>
                                </td>
                                <td class="text-end fw-bold @(c.Status == "Aprobado" ? "text-danger" : "text-muted")">
                                    @(c.Status == "Aprobado" ? "-" : "")@c.Amount.ToString("C2")
                                </td>
                                <td>
                                    @if (c.CommerceName == "AVANCE")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-cash-coin me-1"></i>AVANCE
                                        </span>
                                    }
                                    else
                                    {
                                        <span>@c.CommerceName</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (c.Status == "Aprobado")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            <i class="bi bi-check-circle me-1"></i>APROBADO
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                            <i class="bi bi-x-circle me-1"></i>RECHAZADO
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
