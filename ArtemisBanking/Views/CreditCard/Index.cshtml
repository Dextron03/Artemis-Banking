@model ArtemisBanking.ViewModels.CreditCardIndexViewModel
@{
    ViewData["Title"] = "Tarjetas de Crédito";
}

<div class="container-fluid px-4 py-4">

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-credit-card-2-front text-primary me-2"></i>Tarjetas de Crédito
            </h2>
            <span class="text-muted small">
                @Model.TotalCount registro(s) — Página @Model.CurrentPage de @(Model.TotalPages == 0 ? 1 : Model.TotalPages)
            </span>
        </div>
        <a asp-action="AssignStep1" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Asignar tarjeta de crédito
        </a>
    </div>

    @if (TempData["Success"] is string ok)
    {
        <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-check-circle-fill"></i> @ok
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-2" role="alert">
            <i class="bi bi-exclamation-circle-fill"></i> @err
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold small">
                        <i class="bi bi-search me-1"></i>Buscar por cédula
                    </label>
                    <input type="text" name="searchIdentity" class="form-control"
                           placeholder="001-0000000-0" value="@Model.SearchIdentity" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small">
                        <i class="bi bi-funnel me-1"></i>Estado
                    </label>
                    <select name="statusFilter" class="form-select">
                        <option value="" selected="@(Model.StatusFilter == null ? "selected" : null)">Activas (por defecto)</option>
                        <option value="true" selected="@(Model.StatusFilter == true ? "selected" : null)">Activas</option>
                        <option value="false" selected="@(Model.StatusFilter == false ? "selected" : null)">Canceladas</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-funnel-fill me-1"></i> Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary flex-fill text-center">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between py-3">
            <span class="fw-bold">
                <i class="bi bi-table me-2 text-primary"></i>Listado de Tarjetas
            </span>
            <span class="badge bg-primary rounded-pill">@Model.Cards.Count() visible(s)</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Número</th>
                            <th>Cliente</th>
                            <th class="text-end">Límite</th>
                            <th class="text-center">Vencimiento</th>
                            <th class="text-end">Deuda Total</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Cards.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                    No se encontraron tarjetas con los filtros aplicados.
                                </td>
                            </tr>
                        }
                        @foreach (var card in Model.Cards)
                        {
                            <tr class="@(!card.IsActive ? "table-secondary" : "")">
                                <td>
                                    <code class="fs-6">**** **** **** @card.LastFourDigits</code>
                                </td>
                                <td class="fw-semibold">@card.ClientFullName</td>
                                <td class="text-end fw-bold text-success">@card.CreditLimit.ToString("C2")</td>
                                <td class="text-center">
                                    <span class="badge bg-secondary">@card.ExpireDate</span>
                                </td>
                                <td class="text-end fw-semibold @(card.AmountDebt > 0 ? "text-danger" : "text-muted")">
                                    @card.AmountDebt.ToString("C2")
                                </td>
                                <td class="text-center">
                                    @if (card.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                                            <i class="bi bi-circle-fill me-1" style="font-size:.45rem"></i>Activa
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                                            <i class="bi bi-x-circle-fill me-1"></i>Cancelada
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Detail" asp-route-id="@card.Id"
                                           class="btn btn-outline-info" title="Ver detalles">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (card.IsActive)
                                        {
                                            <a asp-action="Edit" asp-route-id="@card.Id"
                                               class="btn btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Cancel" asp-route-id="@card.Id"
                                               class="btn btn-outline-danger" title="Cancelar">
                                                <i class="bi bi-slash-circle"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-secondary" disabled title="Cancelada">
                                                <i class="bi bi-lock"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-searchIdentity="@Model.SearchIdentity"
                               asp-route-statusFilter="@Model.StatusFilter">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = Math.Max(1, Model.CurrentPage - 2);
                                            i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-searchIdentity="@Model.SearchIdentity"
                                   asp-route-statusFilter="@Model.StatusFilter">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-searchIdentity="@Model.SearchIdentity"
                               asp-route-statusFilter="@Model.StatusFilter">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
