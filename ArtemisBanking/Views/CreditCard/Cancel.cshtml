@model ArtemisBanking.ViewModels.CancelCreditCardViewModel
@{
    ViewData["Title"] = "Cancelar la Tarjeta";
    bool hasDebt = Model.AmountDebt > 0;
}

<div class="container py-5" style="max-width:480px">
    <div class="card shadow border-top border-danger border-3">
        <div class="card-body p-5 text-center">

            <div class="rounded-circle bg-danger bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-4"
                 style="width:72px;height:72px">
                <i class="bi bi-slash-circle text-danger fs-2"></i>
            </div>

            <h4 class="fw-bold mb-3">¿Está seguro que desea cancelar la tarjeta?</h4>

            <div class="bg-dark text-white rounded-3 d-inline-block px-4 py-2 mb-4">
                <div class="text-white-50 small mb-1" style="letter-spacing:.08em">NÚMERO DE TARJETA</div>
                <div class="font-monospace fw-bold fs-5 text-warning">
                    **** **** **** @Model.LastFourDigits
                </div>
            </div>

            @if (hasDebt)
            {
                <div class="alert alert-danger d-flex align-items-start gap-2 text-start mb-4">
                    <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0 mt-1"></i>
                    <div>
                        <strong>Cancelación bloqueada</strong><br />
                        Para cancelar esta tarjeta, el cliente debe saldar la totalidad de la deuda pendiente.<br />
                        <span class="fw-bold">Deuda pendiente: @Model.AmountDebt.ToString("C2")</span>
                    </div>
                </div>
                <a asp-action="Index" class="btn btn-secondary w-100">
                    <i class="bi bi-arrow-left me-1"></i> Volver al listado
                </a>
            }
            else
            {
                <p class="text-muted mb-4">
                    Esta acción es <strong>irreversible</strong>. La tarjeta quedará cancelada
                    y no podrá utilizarse para nuevos consumos o pagos.
                </p>

                <form method="post" asp-action="Cancel">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-flex gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </a>
                        <button type="submit" class="btn btn-danger flex-fill">
                            <i class="bi bi-check-circle me-1"></i> Aceptar
                        </button>
                    </div>
                </form>
            }
        </div>
    </div>
</div>
