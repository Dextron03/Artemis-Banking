@model WithdrawalViewModel
@{
    ViewData["Title"] = "Realizar Retiro";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="bi bi-arrow-up-circle"></i> Realizar Retiro</h4>
                </div>
                <div class="card-body bg-light">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger fw-bold mb-3">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        </div>
                    }

                    <form asp-controller="Cashier" asp-action="Withdrawal" method="post">
                        
                        <div class="mb-3">
                            <label asp-for="AccountNumber" class="form-label fw-bold">Número de cuenta origen</label>
                            <input asp-for="AccountNumber" class="form-control" placeholder="Ej: 123456789" />
                            <span asp-validation-for="AccountNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Amount" class="form-label fw-bold">Monto a retirar (RD$)</label>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger">Siguiente Paso</button>
                            <a asp-controller="Cashier" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>