@{
    ViewData["Title"] = "Panel de Cajero";
}

<div class="container mt-5">
    <h2 class="mb-4 text-dark fw-bold"><i class="bi bi-wallet2"></i> Panel de Operaciones - Cajero</h2>
    <hr />

    <div class="row g-4 mt-2">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-top border-primary border-4 hover-card">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-primary mb-3">⬇️</div>
                    <h4 class="card-title fw-bold">Depósito</h4>
                    <p class="text-muted">Ingresar dinero a una cuenta de ahorros.</p>
                    <a asp-controller="Cashier" asp-action="Deposit" class="btn btn-primary w-100 mt-2">Realizar Depósito</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-top border-danger border-4 hover-card">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-danger mb-3">⬆️</div>
                    <h4 class="card-title fw-bold">Retiro</h4>
                    <p class="text-muted">Extraer fondos de una cuenta de ahorros.</p>
                    <a asp-controller="Cashier" asp-action="Withdrawal" class="btn btn-outline-danger w-100 mt-2">Realizar Retiro</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-top border-success border-4 hover-card">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-success mb-3">↔️</div>
                    <h4 class="card-title fw-bold">Transferencia</h4>
                    <p class="text-muted">Mover dinero entre dos cuentas del banco.</p>
                    <a asp-controller="Cashier" asp-action="Transfer" class="btn btn-outline-success w-100 mt-2">Realizar Transferencia</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 shadow-sm border-0 border-top border-warning border-4 hover-card">
                <div class="card-body text-center p-4">
                    <div class="display-4 text-warning mb-3">💳</div>
                    <h4 class="card-title fw-bold">Pago de Productos</h4>
                    <p class="text-muted">Pagar cuotas de préstamos o tarjetas.</p>
                    <a asp-controller="Cashier" asp-action="Payment" class="btn btn-warning w-100 mt-2 text-dark fw-bold">Realizar Pago</a>                </div>
                </div>
            </div>
        </div>
</div>

<style>
    .hover-card { transition: transform 0.2s ease-in-out; }
    .hover-card:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
</style>