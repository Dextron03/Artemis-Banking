@model Application.ViewModels.DepositViewModel;
@{
    ViewData["Title"] = "Realizar Depósito";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Realizar Depósito</h4>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger fw-bold mb-3"></div>

                    <form asp-controller="Cashier" asp-action="Deposit" method="post">
                        
                        <div class="mb-3">
                            <label asp-for="AccountNumber" class="form-label">Número de cuenta destino</label>
                            <input asp-for="AccountNumber" class="form-control" placeholder="Ej: 123456789" />
                            <span asp-validation-for="AccountNumber" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Amount" class="form-label">Monto a depositar (RD$)</label>
                            <input asp-for="Amount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">Siguiente Paso</button>
                            <a asp-controller="Cashier" asp-action="Index" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>