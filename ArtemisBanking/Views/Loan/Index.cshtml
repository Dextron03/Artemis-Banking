@using Application.ViewModels.Loan
@model LoanIndexViewModel
@{
    ViewData["Title"] = "Gestión de Préstamos";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0"><i class="bi bi-bank"></i> Gestión de Préstamos</h2>
        <a asp-action="SelectClient" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Asignar Préstamo
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="get" class="card card-body mb-3 shadow-sm">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label fw-semibold">Buscar por cédula</label>
                <input type="text" name="identity" value="@Model.Identity"
                       class="form-control" placeholder="Ej. 001-1234567-8" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">Estado</label>
                <select name="status" class="form-select">
                    <option value="true" selected = "@(Model.Status == true || Model.Status == null ? "selected" : "")"> Activos</option>
                    <option value="">Todos</option>
                    <option value="false" selected = "@(Model.Status == false ? "selected" : "")">Completados</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Filtrar
                </button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" class="btn btn-outline-secondary w-100">Limpiar</a>
            </div>
        </div>
    </form>

    <div class="table-responsive shadow-sm">
        <table class="table table-bordered table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Cliente</th>
                    <th>Cédula</th>
                    <th class="text-end">Monto</th>
                    <th class="text-center">Cuotas</th>
                    <th class="text-center">Pagadas</th>
                    <th class="text-end">Pendiente</th>
                    <th class="text-center">Tasa %</th>
                    <th class="text-center">Meses</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Pago</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Loans.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center text-muted py-4">
                            No se encontraron préstamos con los filtros seleccionados.
                        </td>
                    </tr>
                }
                @foreach (var loan in Model.Loans)
                {
                    <tr>
                        <td><code>@loan.IdentifierNumber</code></td>
                        <td>@loan.ClientName</td>
                        <td>@loan.IdentityNumber</td>
                        <td class="text-end">RD$@loan.LoanAmount.ToString("N2")</td>
                        <td class="text-center">@loan.TotalInstallments</td>
                        <td class="text-center">@loan.PaidInstallments</td>
                        <td class="text-end">RD$@loan.PendingAmount.ToString("N2")</td>
                        <td class="text-center">@loan.InterestRate.ToString("N2")%</td>
                        <td class="text-center">@loan.Months</td>
                        <td class="text-center">
                            @if (loan.IsActive)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Completado</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (loan.PaymentStatus == "Al Día")
                            {
                                <span class="badge bg-info text-dark">Al Día</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">En Mora</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@loan.Id"
                               class="btn btn-sm btn-outline-info">
                                <i class="bi bi-eye"></i> Ver
                            </a>
                            <a asp-action="Edit" asp-route-id="@loan.Id"
                               class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           href="?page=@i&identity=@Model.Identity&status=@Model.Status">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
