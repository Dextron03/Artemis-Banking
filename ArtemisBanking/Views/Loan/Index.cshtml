@model IEnumerable<Application.ViewModels.LoanViewModel>

@{
    ViewData["Title"] = "Préstamos";
}

<h2>Préstamos</h2>

<a asp-action="SelectClient" class="btn btn-success mb-3">Asignar préstamo</a>

<form method="get" class="mb-3">
    <input type="text" name="identity" placeholder="Buscar por cédula" class="form-control mb-2" />

    <select name="status" class="form-select mb-2">
        <option value="">Todos</option>
        <option value="true">Activos</option>
        <option value="false">Completados</option>
    </select>

    <button type="submit" class="btn btn-primary">Filtrar</button>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Número</th>
            <th>Cliente</th>
            <th>Monto</th>
            <th>Cuotas</th>
            <th>Pagadas</th>
            <th>Pendiente</th>
            <th>Tasa</th>
            <th>Meses</th>
            <th>Estado</th>
            <th>Pago</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var loan in Model)
        {
            <tr>
                <td>@loan.IdentifierNumber</td>
                <td>@loan.ClientName</td>
                <td>@loan.LoanAmount.ToString("C")</td>
                <td>@loan.TotalInstallments</td>
                <td>@loan.PaidInstallments</td>
                <td>@loan.PendingAmount.ToString("C")</td>
                <td>@loan.InterestRate %</td>
                <td>@loan.Months</td>
                <td>@(loan.IsActive ? "Activo" : "Completado")</td>
                <td>@loan.PaymentStatus</td>
                <td>
                    <a asp-action="Details" asp-route-id="@loan.Id" class="btn btn-info btn-sm">Ver</a>
                    <a asp-action="Edit" asp-route-id="@loan.Id" class="btn btn-warning btn-sm">Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                <a class="page-link" href="?page=@i">@i</a>
            </li>
        }
    </ul>
</nav>