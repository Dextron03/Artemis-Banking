@using Application.ViewModels.Loan
@model EditLoanRateViewModel
@{
    ViewData["Title"] = "Editar Tasa de Interés";
}

<div class="container mt-3" style="max-width:480px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">
                <i class="bi bi-percent"></i> Editar Tasa de Interés
            </h4>
        </div>
        <div class="card-body">

            <div class="alert alert-info small mb-3">
                <i class="bi bi-info-circle"></i>
                Solo se recalcularán las cuotas con fecha de pago <strong>posterior a hoy</strong>.
                Las cuotas vencidas o ya pagadas <strong>no se modificarán</strong>.
            </div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        @foreach (var error in ViewData.ModelState.Values
                                            .SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form method="post" asp-action="Edit" asp-controller="Loan">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="LoanId" />

                <div class="mb-3">
                    <label asp-for="InterestRate" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <input asp-for="InterestRate"
                               class="form-control"
                               type="text"
                               inputmode="decimal"
                               placeholder="Ej: 0.2 o 12.5" />
                        <span class="input-group-text">% anual</span>
                    </div>
                    <span asp-validation-for="InterestRate" class="text-danger small"></span>
                    <div class="form-text text-muted">
                        Usa punto como separador decimal. Ej: <strong>0.2</strong> = 0.2% anual.
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-warning fw-semibold">
                        <i class="bi bi-arrow-repeat"></i> Actualizar tasa
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelector("form").addEventListener("submit", function () {
            const field = document.getElementById("InterestRate");
            if (field) {
                field.value = field.value.replace(",", ".");
            }
        });
    </script>
}
