@model CreateLoanViewModel

<h2>Crear Préstamo</h2>

<form method="post" asp-action="Create" asp-controller="Loan">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="UserId" />

    <label>Monto</label>
    <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control" />

    <label>Meses</label>
    <select asp-for="Months" asp-items="Model.MonthOptions" class="form-select">
        <option value="">Seleccione plazo</option>
    </select>

    <label>Tasa de interés (%)</label>
    <input asp-for="InterestRate" class="form-control" />

    <br />

    <button class="btn btn-primary">Crear</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>