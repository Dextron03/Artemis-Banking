@using Application.ViewModels
@using Application.ViewModels.Login
@using Application.ViewModels.User
@model SaveUserViewModel

<h2>@(Model.Id == null ? "Crear" : "Editar") Usuario</h2>

<form asp-action="@(Model.Id == null ? "Create" : "Edit")" method="post">

    <input asp-for="FirstName" placeholder="Nombre" />
    <span asp-validation-for="FirstName"></span>

    <input asp-for="LastName" placeholder="Apellido" />
    <span asp-validation-for="LastName"></span>

    <input asp-for="Cedula" placeholder="Cédula" />
    <span asp-validation-for="Cedula"></span>

    <input asp-for="Email" placeholder="Correo" />
    <span asp-validation-for="Email"></span>

    @if (Model.Id == null)
    {
        <input asp-for="Password" type="password" placeholder="Nueva contraseña (dejar vacío para no cambiar)" />
        <input asp-for="ConfirmPassword" type="password" placeholder="Confirmar nueva contraseña" />
        <span asp-validation-for="ConfirmPassword"></span>

        <select asp-for="Role" asp-items="Model.Roles" id="roleSelect">
            <option value="">Seleccione un rol</option>
        </select>

        <div id="montoDiv" style="display:none;">
            <input asp-for="InitialAmount" placeholder="Monto inicial" />
        </div>
    }
    else
    {
        <input asp-for="Id" type="hidden" />
        <input asp-for="Role" type="hidden" />

        <input asp-for="Username" placeholder="Usuario" />
        <span asp-validation-for="Username"></span>

        <input asp-for="Password" type="password" placeholder="Nueva contraseña (opcional)" />
        <input asp-for="ConfirmPassword" type="password" placeholder="Confirmar nueva contraseña" />
        <span asp-validation-for="ConfirmPassword"></span>

        @if (Model.Role == "Cliente")
        {
            <input asp-for="AdditionalAmount" placeholder="Monto adicional (RD$)" />
            <span asp-validation-for="AdditionalAmount"></span>
        }
    }

    <button type="submit">Guardar</button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const role = document.getElementById("roleSelect");
        const monto = document.getElementById("montoDiv");
        if (role) {
            role.addEventListener("change", function () {
                monto.style.display = this.value === "Cliente" ? "block" : "none";
            });
        }
    </script>
}