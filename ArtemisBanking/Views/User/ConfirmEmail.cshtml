@{
    ViewData["Title"] = "Activación de Cuenta";
    bool success = ViewBag.Success ?? false;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5">
                    @if (success)
                    {
                        <div class="mb-4">
                            <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                        </div>
                        <h2 class="fw-bold text-dark">¡Cuenta Activada!</h2>
                        <p class="text-muted fs-5 mb-4">
                            El usuario ha sido activado correctamente y ya puede iniciar sesión en el sistema.
                        </p>
                        <div class="d-grid">
                            <a asp-controller="User" asp-action="Index" class="btn btn-primary btn-lg shadow-sm">
                                Volver al Listado de Usuarios
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem;"></i>
                        </div>
                        <h2 class="fw-bold text-dark">Error de Activación</h2>
                        <p class="text-muted fs-5 mb-4">
                            No se pudo activar la cuenta. El enlace puede haber expirado o el token es inválido.
                        </p>
                        <div class="d-grid">
                            <a asp-controller="User" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                                Ir a Gestión de Usuarios
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>