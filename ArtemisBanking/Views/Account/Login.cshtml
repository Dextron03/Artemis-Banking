@using Application.ViewModels;
@using Application.ViewModels.Login
@model LoginViewModel

@{
    ViewData["Title"] = "Iniciar sesión";
}

<style>
    body {
        background: linear-gradient(135deg, #1a0125, #2e004f);
        height: 100vh;
    }

    .login-card {
        background-color: #2b0a3d;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.4);
        color: white;
    }

    .form-control {
        background-color: #3b0f52;
        border: none;
        color: white;
    }

    .form-control:focus {
        background-color: #4c1668;
        color: white;
        box-shadow: none;
        border: 1px solid #a855f7;
    }

    .btn-bank {
        background: linear-gradient(135deg, #6b21a8, #9333ea);
        border: none;
        font-weight: bold;
        color: #ffffff;
    }

    .btn-bank:hover {
        background: linear-gradient(135deg, #7e22ce, #a855f7);
    }

    .bank-title {
        font-weight: bold;
        letter-spacing: 1px;
    }
</style>

<div class="container d-flex justify-content-center align-items-center" style="height:100vh;">
    
    <div class="col-md-4">
        <div class="card login-card p-4">

            <div class="text-center mb-4">
                <h3 class="bank-title">
                     Artemis Banking
                </h3>
                <p class="text-light">Acceso seguro a su cuenta</p>
            </div>

            <form asp-action="Login" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label"></label>
                    <input asp-for="UserName" class="form-control" placeholder="Ingrese su usuario" />
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Ingrese su contraseña" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="d-grid mt-4">
                    <button type="submit" class="btn btn-bank btn-lg">
                        Iniciar sesión
                    </button>
                </div>

            </form>

        </div>
    </div>

</div>