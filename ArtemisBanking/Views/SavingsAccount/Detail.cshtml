@model Application.ViewModels.SavingsAccount.Queries.SavingsAccountDetailViewModel
@{
    ViewData["Title"] = "Detalle de Cuenta";
}

<div class="container-fluid py-4">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver atras
        </a>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-receipt me-2 text-primary"></i>Transacciones de la Cuenta
        </h2>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 bg-primary text-white h-100">
                <div class="card-body">
                    <div class="text-white-50 small mb-1">No. de Cuenta</div>
                    <div class="fs-5 fw-bold font-monospace">@Model.AccountNumber</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-success text-white h-100">
                <div class="card-body">
                    <div class="text-white-50 small mb-1">Balance</div>
                    <div class="fs-5 fw-bold">@Model.Balance.ToString("C2")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-light h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Tipo</div>
                    @if (Model.IsPrincipal)
                    {
                        <span class="badge bg-primary fs-6">Principal</span>
                    }
                    else
                    {
                        <span class="badge bg-info text-dark fs-6">Secundaria</span>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 bg-light h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Estado</div>
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success fs-6">Activa</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6">Cancelada</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 bg-light mb-3">
        <div class="card-body py-2">
            <strong>Cliente:</strong> @Model.ClientFullName
            &nbsp;|&nbsp;
            <strong>Fecha de creacion:</strong> @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex align-items-center gap-2">
            <i class="bi bi-arrow-left-right text-primary"></i>
            <h5 class="mb-0 fw-semibold">Historial de Transacciones</h5>
            <span class="badge bg-secondary ms-1">@Model.Transactions.Count</span>
        </div>
        <div class="card-body p-0">
            @if (!Model.Transactions.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    No hay transacciones registradas para esta cuenta.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Fecha</th>
                                <th>Monto</th>
                                <th>Tipo</th>
                                <th>Origen</th>
                                <th>Beneficiario</th>
                                <th>Estado</th>
                                <th>Concepto</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in Model.Transactions)
                            {
                                <tr>
                                    <td class="ps-4 text-nowrap">
                                        @tx.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="fw-semibold">
                                        @if (tx.TransactionType == "CREDITO")
                                        {
                                            <span class="text-success">+@tx.Amount.ToString("C2")</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">-@tx.Amount.ToString("C2")</span>
                                        }
                                    </td>
                                    <td>
                                        @if (tx.TransactionType == "CREDITO")
                                        {
                                            <span class="badge bg-success">CREDITO</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">DEBITO</span>
                                        }
                                    </td>
                                    <td class="font-monospace small">@tx.Origin</td>
                                    <td class="font-monospace small">@tx.Beneficiary</td>
                                    <td>
                                        @if (tx.Status == "APROBADA")
                                        {
                                            <span class="badge bg-success">APROBADA</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">RECHAZADO</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@tx.Concept</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
