@model Application.ViewModels.SavingsAccount.Management.CreateSavingsAccountViewModel
@{
    ViewData["Title"] = "Configurar Cuenta de Ahorro";
}

<div class="container py-4" style="max-width:640px;">

    <div class="d-flex align-items-center gap-3 mb-4">
        <a asp-action="SelectClient" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver a selección de cliente
        </a>
        <h2 class="fw-bold mb-0">
            <i class="bi bi-piggy-bank me-2 text-primary"></i>Asignar Cuenta
        </h2>
    </div>

    <div class="card bg-light border-0 mb-4">
        <div class="card-body">
            <p class="text-muted mb-1 small">Cliente seleccionado</p>
            <div class="d-flex justify-content-between align-items-center">
                <span class="fw-bold fs-5">@Model.ClientFullName</span>
                <span class="text-muted">Cédula: <strong>@Model.ClientIdentityNumber</strong></span>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <h5 class="mb-0 fw-semibold">Cuenta de Ahorro Secundaria</h5>
        </div>
        <div class="card-body">
            <form method="post" asp-action="CreateAccount">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ClientId" />
                <input type="hidden" asp-for="ClientFullName" />
                <input type="hidden" asp-for="ClientIdentityNumber" />

                <div class="mb-4">
                    <label asp-for="InitialBalance" class="form-label fw-semibold">
                        Balance Inicial
                        <span class="text-muted fw-normal">(puede ser 0)</span>
                    </label>
                    <div class="input-group">
                        <span class="input-group-text">RD$</span>
                        <input asp-for="InitialBalance"
                               type="number"
                               step="0.01"
                               min="0"
                               class="form-control form-control-lg"
                               placeholder="0.00" />
                    </div>
                    <span asp-validation-for="InitialBalance" class="text-danger small"></span>
                </div>

                <div class="d-flex gap-3 justify-content-end mt-4">
                    <a asp-action="SelectClient" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left me-1"></i> Cambiar cliente
                    </a>
                    <button type="submit" class="btn btn-success px-5">
                        <i class="bi bi-check-circle me-1"></i> Confirmar asignación
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
