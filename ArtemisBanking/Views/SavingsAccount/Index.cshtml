@model Application.ViewModels.SavingsAccount.SavingsAccountIndexViewModel
@{
    ViewData["Title"] = "Cuentas de Ahorro";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">
            <i class="bi bi-piggy-bank me-2 text-primary"></i>Gestión de Cuentas de Ahorro
        </h2>
        <a asp-action="SelectClient" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Asignar cuenta de ahorro
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Buscar por cédula</label>
                    <input type="text" name="searchIdentityNumber"
                           value="@Model.SearchIdentityNumber"
                           class="form-control"
                           placeholder="Ej: 00100100100" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Estado</label>
                    <select name="filterStatus" class="form-select">
                        <option value="active" selected = "@(Model.FilterStatus == "active"     ? "selected" : "")">Activas</option>
                        <option value="cancelled" selected = "@(Model.FilterStatus == "cancelled"  ? "selected" : "")">Canceladas</option>
                        <option value="" selected="@(string.IsNullOrEmpty(Model.FilterStatus) ? "selected" : null)">Todos</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Tipo</label>
                    <select name="filterType" class="form-select">
                        <option value="principal" selected = "@(Model.FilterType == "principal" ? "selected" : "")">Principal</option>
                        <option value="secondary" selected = "@(Model.FilterType == "secondary" ? "selected" : "")">Secundaria</option>
                        <option value="" selected="@(string.IsNullOrEmpty(Model.FilterType) ? "selected" : null)">Todos</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-funnel me-1"></i>Filtrar
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Limpiar">
                        <i class="bi bi-x-circle"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <span class="fw-semibold text-muted">
                Total: <strong class="text-dark">@Model.TotalCount</strong> cuentas
            </span>
        </div>

        <div class="card-body p-0">
            @if (!Model.Accounts.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                    No se encontraron cuentas con los filtros aplicados.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">No. Cuenta</th>
                                <th>Cliente</th>
                                <th>Balance</th>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var acc in Model.Accounts)
                            {
                                <tr>
                                    <td class="ps-4 font-monospace fw-semibold">@acc.AccountNumber</td>
                                    <td>@acc.ClientFullName</td>
                                    <td class="fw-semibold text-success">@acc.Balance.ToString("C2")</td>
                                    <td>
                                        @if (acc.IsPrincipal)
                                        {
                                            <span class="badge bg-primary">Principal</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark">Secundaria</span>
                                        }
                                    </td>
                                    <td>
                                        @if (acc.IsActive)
                                        {
                                            <span class="badge bg-success">Activa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Cancelada</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Detail" asp-route-id="@acc.Id"
                                           class="btn btn-sm btn-outline-primary me-1">
                                            <i class="bi bi-eye"></i> Ver detalles
                                        </a>
                                        @if (!acc.IsPrincipal && acc.IsActive)
                                        {
                                            <a asp-action="Cancel" asp-route-id="@acc.Id"
                                               class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-x-circle"></i> Cancelar
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <div class="card-footer bg-white d-flex justify-content-center py-3">
                <nav>
                    <ul class="pagination mb-0">
                        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-searchIdentityNumber="@Model.SearchIdentityNumber"
                               asp-route-filterStatus="@Model.FilterStatus"
                               asp-route-filterType="@Model.FilterType">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>
                        @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-searchIdentityNumber="@Model.SearchIdentityNumber"
                                   asp-route-filterStatus="@Model.FilterStatus"
                                   asp-route-filterType="@Model.FilterType">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-searchIdentityNumber="@Model.SearchIdentityNumber"
                               asp-route-filterStatus="@Model.FilterStatus"
                               asp-route-filterType="@Model.FilterType">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>
