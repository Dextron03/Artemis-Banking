@model Application.ViewModels.SavingsAccount.Management.CancelSavingsAccountViewModel
@{
    ViewData["Title"] = "Cancelar Cuenta de Ahorro";
}

<div class="container py-5" style="max-width:560px;">
    <div class="card shadow border-0">
        <div class="card-header bg-danger text-white py-3">
            <h5 class="mb-0 fw-bold">
                <i class="bi bi-exclamation-triangle me-2"></i>Confirmación de Cancelación
            </h5>
        </div>

        <div class="card-body text-center py-5 px-4">
            <i class="bi bi-x-circle text-danger" style="font-size:3.5rem;"></i>

            <h4 class="mt-4 fw-semibold">
                ¿Está seguro que desea cancelar la cuenta?
                <span class="font-monospace text-danger d-block mt-1">@Model.AccountNumber</span>
            </h4>

            @if (Model.Balance > 0)
            {
                <div class="alert alert-warning mt-4 text-start">
                    <i class="bi bi-info-circle me-1"></i>
                    Esta cuenta tiene un saldo de <strong>@Model.Balance.ToString("C2")</strong>.
                    Al confirmar, ese monto será transferido automáticamente a la
                    cuenta principal del cliente.
                </div>
            }
            else
            {
                <p class="text-muted mt-3">
                    Cliente: <strong>@Model.ClientFullName</strong><br />
                    Esta acción no puede deshacerse.
                </p>
            }
        </div>

        <div class="card-footer bg-white d-flex justify-content-between py-3 px-4">
            <a asp-action="Index" class="btn btn-outline-secondary px-4">
                <i class="bi bi-arrow-left me-1"></i> Volver
            </a>
            <form method="post" asp-action="Cancel">
                <input type="hidden" asp-for="Id" />
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger px-5">
                    <i class="bi bi-check2 me-1"></i> Sí, Cancelar Cuenta
                </button>
            </form>
        </div>
    </div>
</div>
